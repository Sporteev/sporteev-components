{
  "name": "@sporteev/sporteev-components",
  "main": "dist/sporteev-components.umd.js",
  "module": "dist/sporteev-components.es.js",
  "types": "dist/sporteev-components.d.ts",
  "private": false,
  "version": "2.2.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.12.1",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/sporteev-components.d.ts",
      "import": "./dist/sporteev-components.es.js",
      "require": "./dist/sporteev-components.umd.js"
    },
    "./theme.css": "./src/theme/theme.css",
    "./theme/tokens": "./src/theme/tokens.cjs"
  },
  "files": [
    "dist/",
    "src/components/",
    "src/lib/",
    "src/theme/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "generate:theme": "node scripts/generate-theme-css.mjs",
    "prebuild": "pnpm run generate:theme",
    "build": "pnpm run clean && vite build",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,mdx}\"",
    "setup:ide": "bash scripts/setup-ide.sh",
    "setup:ide:cursor": "bash scripts/setup-ide.sh ide:cursor",
    "setup:ide:claude": "bash scripts/setup-ide.sh ide:claude",
    "setup:ide:kiro": "bash scripts/setup-ide.sh ide:kiro",
    "prepare": "pnpm run build",
    "release:patch": "pnpm run build && pnpm version patch -m \"Release v%s\" && pnpm publish --access public",
    "release:minor": "pnpm run build && pnpm version minor -m \"Release v%s\" && pnpm publish --access public",
    "release:major": "pnpm run build && pnpm version major -m \"Release v%s\" && pnpm publish --access public"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@solar-icons/react-perf": "^2.1.1",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-interactions": "^8.6.0",
    "@storybook/addon-links": "^8.6.0",
    "@storybook/blocks": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/test": "^8.6.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "eslint-plugin-storybook": "^0.11.0",
    "globals": "^15.9.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-dts": "^4.5.3"
  },
  "peerDependencies": {
    "@solar-icons/react-perf": "^2.1.1",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
